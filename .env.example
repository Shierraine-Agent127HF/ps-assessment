# Copy this file to .env and fill in your values
# Never commit .env to git

# Server-side key for AI essay scoring via Google Gemini (Vercel function). Keep secret.
GEMINI_API_KEY=AIza...

# Optional: override the Gemini model (default: gemini-2.5-flash). e.g. gemini-3.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Google Apps Script Web App URL that validates codes + stores results (ends in /exec).
# Baked into the frontend at build time — set it in Vercel and redeploy after changing.
VITE_ASSESSMENT_URL=https://script.google.com/macros/s/.../exec
